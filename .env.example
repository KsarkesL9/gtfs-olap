# Zmienne środowiskowe dla GTFS OLAP ETL.
# Skopiuj do .env i dostosuj wartości.
# Skrypty czytają je przez os.environ.get() z fallbackami,
# więc jeśli nie ustawisz — użyją domyślnych (poniżej).

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gtfs_olap
GTFS_RT_URL=https://gtfsrt.transportgzm.pl:5443/gtfsrt/gzm/tripUpdates
POLL_INTERVAL_S=20
